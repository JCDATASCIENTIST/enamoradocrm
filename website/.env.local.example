# Copy to .env.local for local testing. Never commit real secrets.

# --- Brevo (recommended — free tier) ---
# Create account: https://www.brevo.com
# Settings → SMTP & API → Generate API key
# Senders & IP → verify hello@enamoradoinsurancecompany.com (or your sender)
BREVO_API_KEY=xkeysib-...
CONTACT_NOTIFY_EMAIL=hello@enamoradoinsurancecompany.com
BREVO_SENDER_EMAIL=hello@enamoradoinsurancecompany.com
BREVO_SENDER_NAME=Enamorado Insurance

# --- Optional fallback (Zapier Catch Hook) ---
# WEBSITE_CONTACT_WEBHOOK=https://hooks.zapier.com/hooks/catch/...
