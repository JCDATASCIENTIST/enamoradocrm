# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real secrets.

# --- Supabase (required) ---
# Found in: Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co

# Preferred (new key format, starts with sb_publishable_)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_YOUR-KEY
# Legacy (anon JWT) — only set if your project still uses legacy keys.
# NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Server-only secret. NEVER expose to the browser.
# Used for admin operations (creating users via invitation, etc.)
# Preferred (new key format, starts with sb_secret_):
SUPABASE_SECRET_KEY=sb_secret_YOUR-KEY
# Legacy service_role JWT — only set if your project still uses legacy keys.
# SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# Supabase project ref (used by `npm run db:types`)
SUPABASE_PROJECT_REF=YOUR-PROJECT-REF

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Cron (Zapier reminder batch — Vercel Cron or external scheduler) ---
CRON_SECRET=generate-a-long-random-string

# --- Optional: Zapier webhook URLs (Workstream B, Path B payloads only) ---
# ZAPIER_FOLLOWUP_REMINDER_WEBHOOK=
# ZAPIER_RENEWAL_REMINDER_WEBHOOK=
# ZAPIER_NEW_PROSPECT_WEBHOOK=
